# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (MySQL via WampServer)
DB_CLIENT=mysql2
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=resto_rms

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_SECRET=dev-secret-change-in-production-minimum-32-chars!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=*

# File Storage (local for dev)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Log level
LOG_LEVEL=debug
